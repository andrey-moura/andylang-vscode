{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "lavi",
	"patterns": [
		{
			"name": "string.quoted.double.lavi",
			"match": "\"([^\"\\\\]|\\\\.)*\""
		},
		{
			"name": "string.quoted.single.lavi",
			"match": "'([^'\\\\]|\\\\.)*'"
		}
	],
	"repository": {},
	"scopeName": "source.lavi"
}